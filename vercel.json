{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/ronaldo",
      "destination": "/ronaldo.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
