{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/discipline",
      "destination": "/discipline.html"
    },
    {
      "source": "/ronaldo",
      "destination": "/ronaldo.html"
    },
    {
      "source": "/matcha",
      "destination": "/matcha.html"
    },
    {
      "source": "/archive",
      "destination": "/archive.html"
    },
    {
      "source": "/in-process",
      "destination": "/in-process.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
